loading ESP32-C3-DevKitC-02 board

ld! target/RISC-V/esp32/c3.mu4

ld target/common/serial.mu4
.ifdef serial-target
   -d devkit-style   | for getting it into download mode
   ld target/RISC-V/esp32/uart-bootloader.mu4
.then
