loading WCH CH32V203C8T6-EVT board

| load chip details and build environment
ld! target/RISC-V/ch32v/203_8.mu4

| user is likely using a link-e
ld target/RISC-V/ch32v/link-e.mu4

| and might have a serial connection to the board
ld target/common/serial.mu4
.ifdef serial-target
   ld target/RISC-V/chat-host.mu4
.then
